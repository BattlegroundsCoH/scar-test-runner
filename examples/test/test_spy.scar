describe("spy system", function()

    describe("spy()", function()
        it("should create a callable no-op spy", function()
            local s = spy()
            s()
            s()
            assert_called(s, 2)
        end)

        it("should wrap an existing function", function()
            local s = spy(function(a, b) return a + b end)
            local result = s(3, 4)
            assert_eq(7, result)
            assert_called(s, 1)
        end)
    end)

    describe("assert_called", function()
        it("should pass when count matches", function()
            local s = spy()
            s()
            s()
            s()
            assert_called(s, 3)
        end)

        it("should fail when count does not match", function()
            local s = spy()
            s()
            assert_error(function()
                assert_called(s, 5)
            end)
        end)
    end)

    describe("assert_not_called", function()
        it("should pass when spy was never called", function()
            local s = spy()
            assert_not_called(s)
        end)

        it("should fail when spy was called", function()
            local s = spy()
            s()
            assert_error(function()
                assert_not_called(s)
            end)
        end)
    end)

    describe("assert_called_with", function()
        it("should match exact arguments", function()
            local s = spy()
            s(1, "hello", true)
            assert_called_with(s, 1, "hello", true)
        end)

        it("should match among multiple calls", function()
            local s = spy()
            s("first")
            s("second")
            s("third")
            assert_called_with(s, "second")
        end)

        it("should fail when no call matches", function()
            local s = spy()
            s(1, 2)
            assert_error(function()
                assert_called_with(s, 99, 100)
            end)
        end)

        it("should fail when spy was never called", function()
            local s = spy()
            assert_error(function()
                assert_called_with(s, "anything")
            end)
        end)

        it("should distinguish argument count", function()
            local s = spy()
            s(1, 2, 3)
            assert_error(function()
                assert_called_with(s, 1, 2)
            end)
        end)
    end)
end)
